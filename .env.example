DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_TIME_ZONE=America/New_York

POSTGRES_DB=taskforge
POSTGRES_USER=taskforge
POSTGRES_PASSWORD=taskforge
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Set to True only when you want a local SQLite fallback for quick checks.
USE_SQLITE=False

# OpenAI parser settings. Keep the real API key only in your local `.env`
# or deployment environment variables. Never commit it to Git.
OPENAI_API_KEY=
OPENAI_TASK_PARSER_MODEL=gpt-5-mini
USE_MOCK_TASK_PARSER=True
